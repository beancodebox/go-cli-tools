# Claude Code Multi-Account Manager - Shell Wrapper
# 자동 로드: ~/.bashrc 또는 ~/.zshrc에서
# [ -f ~/.bashrc.ccs ] && source ~/.bashrc.ccs

# === ccs 환경변수 설정 함수 ===
ccs() {
  if [ "$1" = "use" ] && [ -n "$2" ]; then
    export CLAUDE_CODE_OAUTH_TOKEN=$( ~/.local/bin/ccs get-token "$2" )
  elif [ "$1" = "resume" ]; then
    local account_name=$(cat ~/.claude-accounts/.last-active 2>/dev/null)
    if [ -n "$account_name" ]; then
      export CLAUDE_CODE_OAUTH_TOKEN=$( ~/.local/bin/ccs get-token "$account_name" )
    fi
  fi
  ~/.local/bin/ccs "$@"
}

# === 새 쉘 시작 시 마지막 활성 계정 자동 로드 ===
if [ -f ~/.claude-accounts/.last-active ]; then
  account=$(cat ~/.claude-accounts/.last-active 2>/dev/null)
  if [ -n "$account" ]; then
    ccs resume 2>/dev/null || {
      # resume 실패 시 토큰만 로드
      if [ -f ~/.claude-accounts/"$account"/.token ]; then
        export CLAUDE_CODE_OAUTH_TOKEN=$(cat ~/.claude-accounts/"$account"/.token)
      fi
    }
  fi
fi

# === Zsh completion fpath 설정 및 초기화 ===
if [ -n "$ZSH_VERSION" ]; then
  fpath=("${XDG_DATA_HOME:-$HOME/.local/share}/zsh/site-functions" $fpath)
  autoload -U compinit && compinit -i
fi

# === Bash completion 로드 ===
# XDG 표준 경로 우선, 레거시 경로도 지원
for dir in \
    "${XDG_DATA_HOME:-$HOME/.local/share}/bash-completion.d" \
    "$HOME/.bash_completion.d"; do
  if [ -f "$dir/ccs" ]; then
    source "$dir/ccs" 2>/dev/null
    break
  fi
done
